#!/bin/sh /etc/rc.common

START=95
STOP=01
USE_PROCD=1

PROG="/usr/bin/levelmeter-daemon"
PID_FILE="/var/run/levelmeter.pid"

start_service() {
    local enabled
    local device
    local channels
    local sample_rate
    
    config_load levelmeter
    config_get enabled general enabled 0
    config_get device general device "hw:0,0"
    config_get channels general channels 2
    config_get sample_rate general sample_rate 48000
    
    if [ "$enabled" -eq 0 ]; then
        echo "Level Meter service is disabled. Enable it in LuCI or via UCI."
        return 0
    fi
    
    procd_open_instance
    procd_set_param command "$PROG" config "$device" "$channels" "$sample_rate"
    procd_set_param respawn 3600 5 0
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_set_param pidfile "$PID_FILE"
    procd_close_instance
    
    echo "Level Meter daemon started with device: $device"
}

stop_service() {
    killall arecord 2>/dev/null
    rm -f /tmp/levelmeter_fifo 2>/dev/null
    echo "Level Meter daemon stopped"
}

service_triggers() {
    procd_add_reload_trigger "levelmeter"
}
